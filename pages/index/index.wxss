/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.7), transparent 28%),
    linear-gradient(180deg, #eaf2f8 0%, #dce7f2 52%, #d6e2ec 100%);
  padding: 48rpx 28rpx 64rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 决策值积分徽章 */
.points-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 104, 128, 0.12);
  backdrop-filter: blur(8rpx);
  z-index: 10;
  transition: all 0.2s ease;
}

.points-badge:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 8rpx rgba(74, 104, 128, 0.16);
}

.points-icon {
  font-size: 28rpx;
}

.points-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #355c7d;
}

.ambient {
  position: absolute;
  border-radius: 50%;
  filter: blur(12rpx);
  opacity: 0.7;
}

.ambient-left {
  top: 120rpx;
  left: -60rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(182, 208, 224, 0.6);
}

.ambient-right {
  right: -40rpx;
  bottom: 260rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(210, 223, 201, 0.58);
}

.hero-card {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 42rpx 34rpx 34rpx;
  margin-bottom: 28rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 18rpx 48rpx rgba(74, 104, 128, 0.14);
  backdrop-filter: blur(18rpx);
}

.brand-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(53, 92, 125, 0.1);
  color: #355c7d;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  margin-bottom: 24rpx;
}

.header-section {
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 68rpx;
  font-weight: 800;
  color: #1f2a37;
  margin-bottom: 18rpx;
  letter-spacing: 2rpx;
}

.sub-title {
  font-size: 34rpx;
  line-height: 1.5;
  color: #243445;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.hero-copy {
  font-size: 26rpx;
  line-height: 1.7;
  color: #5b6b7a;
}

.trust-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.trust-pill {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #516173;
  font-size: 23rpx;
  border: 1rpx solid rgba(137, 162, 181, 0.24);
}

.features-section {
  position: relative;
  z-index: 1;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 30rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.74);
  box-shadow: 0 16rpx 36rpx rgba(86, 112, 130, 0.1);
}

.feature-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 52rpx;
  padding: 0 18rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: rgba(53, 92, 125, 0.12);
  color: #355c7d;
  font-size: 24rpx;
  font-weight: 700;
}

.feature-text {
  font-size: 30rpx;
  color: #243445;
  font-weight: 800;
  margin-bottom: 10rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #637282;
  line-height: 1.65;
}

.start-section {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 12rpx;
  text-align: center;
}

.cta-note {
  font-size: 24rpx;
  line-height: 1.6;
  color: #607181;
  margin: 0 auto 28rpx;
  padding: 0 16rpx;
}

.privacy-note {
  margin: 0 auto 24rpx;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #526474;
  font-size: 23rpx;
  line-height: 1.6;
  box-shadow: 0 10rpx 24rpx rgba(86, 112, 130, 0.08);
}

.history-card {
  margin: 0 auto 26rpx;
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  text-align: left;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(245, 250, 255, 0.9));
  border: 2rpx solid rgba(159, 183, 202, 0.28);
  box-shadow: 0 14rpx 28rpx rgba(86, 112, 130, 0.11);
}

.history-title {
  font-size: 22rpx;
  color: #647687;
}

.history-main {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #243445;
  font-weight: 900;
}

.history-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #4d6578;
  font-weight: 700;
}

.history-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6f8090;
}

.history-btn {
  margin-top: 18rpx;
  width: 100%;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(53, 92, 125, 0.1);
  color: #355c7d;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.history-btn::after {
  border: none;
}

.start-btn {
  width: 100%;
  max-width: 520rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #355c7d 0%, #456f93 100%);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
  border: none;
  box-shadow: 0 16rpx 36rpx rgba(53, 92, 125, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn:active {
  transform: scale(0.95);
  box-shadow: 0 8rpx 20rpx rgba(53, 92, 125, 0.22);
}

.start-btn::after {
  border: none;
}

.footer-note {
  margin-top: 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #72818f;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #355c7d;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: white;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
