/* pages/question/question.wxss */

.container {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.52), transparent 24%),
    radial-gradient(circle at top right, rgba(195, 214, 227, 0.45), transparent 28%),
    linear-gradient(180deg, #eaf2f8 0%, #dde8f1 42%, #d4e0ea 100%);
  padding: 22rpx 24rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 180rpx;
}

.header {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  position: relative;
  margin-bottom: 30rpx;
}

.back-btn {
  position: absolute;
  left: 0;
  display: flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(124, 147, 166, 0.24);
  backdrop-filter: blur(10rpx);
}

.back-icon {
  font-size: 32rpx;
  margin-right: 6rpx;
  color: #38516a;
}

.back-text {
  font-size: 26rpx;
  color: #38516a;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  color: #243445;
}

.progress-container {
  width: 92%;
  margin: 12rpx 0 28rpx;
}

.progress-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-stage {
  font-size: 25rpx;
  color: #33475b;
  font-weight: 700;
}

.progress-hint {
  font-size: 22rpx;
  color: #6d7f8f;
}

.progress-bar {
  height: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(91, 115, 136, 0.14);
  box-shadow: inset 0 2rpx 8rpx rgba(70, 99, 122, 0.1);
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #355c7d 0%, #5b7d8f 100%);
  box-shadow: 0 0 16rpx rgba(53, 92, 125, 0.2);
  transition: width 0.3s ease;
}

.progress-text {
  text-align: left;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #677a8a;
  line-height: 1.6;
}

.progress-subtext {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b8c99;
}

.step-container {
  width: 100%;
  display: flex;
  justify-content: center;
}

.question-card {
  width: 92%;
  padding: 38rpx 32rpx 34rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 251, 253, 0.98) 100%);
  box-shadow: 0 24rpx 50rpx rgba(73, 101, 126, 0.12);
  animation: cardIn 0.4s ease;
}

.question-tag {
  display: inline-flex;
  margin-bottom: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(53, 92, 125, 0.1);
  color: #355c7d;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.question-title {
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.5;
  color: #273746;
  margin-bottom: 30rpx;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.option-btn {
  display: flex;
  align-items: flex-start;
  min-height: 112rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbfd 100%);
  border: 2rpx solid #dce7ef;
  box-sizing: border-box;
  transition: all 0.22s ease;
}

.option-btn:active {
  transform: scale(0.98);
  border-color: #6a8aa6;
  background: linear-gradient(180deg, #eef5fa 0%, #f7fbfd 100%);
  box-shadow: 0 12rpx 26rpx rgba(93, 125, 147, 0.15);
}

.option-btn-selected {
  border-color: #5f7d96;
  background: linear-gradient(180deg, #eef5fa 0%, #f7fbfd 100%);
  box-shadow: 0 16rpx 34rpx rgba(93, 125, 147, 0.16);
}

.option-label {
  width: 58rpx;
  height: 58rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #355c7d 0%, #4f7894 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 20rpx rgba(53, 92, 125, 0.2);
}

.option-body {
  flex: 1;
}

.option-text {
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.4;
  color: #314453;
}

.option-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #7d8e9c;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(234, 242, 248, 0) 0%, rgba(234, 242, 248, 0.96) 28%, #eaf2f8 100%);
  box-sizing: border-box;
}

.next-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #355c7d 0%, #4b7595 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(53, 92, 125, 0.22);
}

.next-btn::after {
  border: none;
}

.next-btn-disabled {
  background: #b8c7d3;
  box-shadow: none;
  color: rgba(255, 255, 255, 0.9);
}

.loading-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(16, 14, 41, 0.68);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 84rpx;
  height: 84rpx;
  margin-bottom: 24rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.26);
  border-top: 8rpx solid #355c7d;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 28rpx;
  color: #ffffff;
  letter-spacing: 1rpx;
}

@keyframes cardIn {
  from {
    opacity: 0;
    transform: translateY(28rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}
