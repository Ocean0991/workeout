/* app.wxss */
/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主色调：克莱因蓝 */
.primary-color {
  color: #1E88E5;
}

.primary-bg {
  background-color: #1E88E5;
}

/* 次要色调：森林绿 */
.secondary-color {
  color: #4CAF50;
}

.secondary-bg {
  background-color: #4CAF50;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 90%;
  margin: 20rpx auto;
  padding: 15rpx 0;
  text-align: center;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  background-color: #1E88E5;
  box-shadow: 0 2rpx 8rpx rgba(30, 136, 229, 0.3);
}

.btn:active {
  opacity: 0.8;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

/* 输入框样式 */
.input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* 滑动条容器 */
.slider-container {
  margin: 20rpx 0;
}

/* 结果展示 */
.result {
  font-size: 48rpx;
  font-weight: bold;
  color: #1E88E5;
  text-align: center;
  margin: 40rpx 0;
}

/* 计划选项样式 */
.plan-option {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.plan-option.active {
  border-color: #1E88E5;
  background-color: rgba(30, 136, 229, 0.05);
}

.plan-option radio {
  margin-right: 20rpx;
}

.plan-option text {
  flex: 1;
  font-size: 28rpx;
}
